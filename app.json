{
  "expo": {
    "name": "KlinkApp",
    "slug": "klink-app",
    "scheme": "klinkapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "platforms": [
      "ios",
      "android"
    ],
    "splash": {
      "backgroundColor": "#2D1B69",
      "resizeMode": "contain",
      "image": "./assets/icon.png"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.klink.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D1B69",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.klink.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-asset",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Klink uses the camera to scan attendance QR codes at church services."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Klink needs access to your photos so you can set a profile picture and share church photos.",
          "cameraPermission": "Klink uses the camera to take a profile picture or photos for church galleries."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#F4A429"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
