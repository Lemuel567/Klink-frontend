{
  "expo": {
    "name": "KlinkApp",
    "slug": "klink-app",
    "scheme": "klinkapp",
    "version": "1.0.0",
    "sdkVersion": "52.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios", "android"],
    "splash": {
      "backgroundColor": "#2D1B69",
      "resizeMode": "contain",
      "image": "./assets/icon.png"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.klink.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D1B69",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.klink.app"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
